# ─── Option A: Frontend on Vercel + Backend hosted separately ─────────────────
# Set VITE_API_BASE_URL to your deployed backend origin (no trailing slash).
# Leave empty for same-origin / local dev (the server serves the frontend).
# Example: VITE_API_BASE_URL=https://parking-backend.example.com
VITE_API_BASE_URL=

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Found in Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
