# Copy this file to .env and fill in your values.
# This file is safe to commit — it contains no real credentials.

# ─── Supabase (Frontend) ───────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Supabase (Backend) ────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# ─── Database ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → Database → Connection string
# Use the "Transaction" pooler URI (port 6543)
DATABASE_URL=postgresql://postgres.your-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# ─── App ───────────────────────────────────────────────────────────────────────
# Your Supabase user UUID — find it in Supabase Dashboard → Authentication → Users
OWNER_OPEN_ID=your-supabase-user-uuid

# ─── API Base URL ──────────────────────────────────────────────────────────────
# Leave empty for local dev. Set to backend URL in production.
# Example: VITE_API_BASE_URL=https://your-backend.up.railway.app
VITE_API_BASE_URL=

# ─── CORS (set on your backend host, not Vercel) ───────────────────────────────
# Comma-separated list of allowed frontend origins
# Example: CORS_ORIGIN=https://your-app.vercel.app
CORS_ORIGIN=
